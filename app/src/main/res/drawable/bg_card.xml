<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Gradient border (glow ring) -->
    <item>
        <shape android:shape="rectangle">
            <corners android:radius="24dp" />
            <gradient
                android:angle="135"
                android:startColor="#254FC3F7"
                android:endColor="#15818CF8" />
        </shape>
    </item>
    <!-- Inner card fill -->
    <item
        android:bottom="1dp"
        android:left="1dp"
        android:right="1dp"
        android:top="1dp">
        <shape android:shape="rectangle">
            <corners android:radius="23dp" />
            <solid android:color="#E50F1829" />
        </shape>
    </item>
</layer-list>
