<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/rootLayout"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_weather_cloudy"
    android:paddingStart="28dp"
    android:paddingEnd="28dp"
    android:paddingTop="52dp"
    android:paddingBottom="40dp">

    <!-- Settings button — top right -->
    <ImageButton
        android:id="@+id/settingsButton"
        android:layout_width="40dp"
        android:layout_height="40dp"
        android:background="?attr/selectableItemBackgroundBorderless"
        android:contentDescription="@string/settings_title"
        android:padding="9dp"
        android:src="@drawable/ic_settings"
        android:tint="@color/text_muted"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Location — top left, vertically centered with settings button -->
    <TextView
        android:id="@+id/locationText"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginEnd="12dp"
        android:text="@string/location_placeholder"
        android:textColor="@color/text_secondary"
        android:textSize="13sp"
        android:fontFamily="sans-serif"
        android:letterSpacing="0.02"
        android:maxLines="1"
        android:ellipsize="end"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toStartOf="@id/settingsButton"
        app:layout_constraintTop_toTopOf="@id/settingsButton"
        app:layout_constraintBottom_toBottomOf="@id/settingsButton" />

    <!-- Refresh button — anchored to bottom -->
    <com.google.android.material.button.MaterialButton
        android:id="@+id/refreshButton"
        android:layout_width="0dp"
        android:layout_height="52dp"
        android:text="@string/refresh"
        android:textColor="@color/text_primary"
        android:textSize="14sp"
        android:textAllCaps="false"
        android:letterSpacing="0.06"
        android:fontFamily="sans-serif-medium"
        app:backgroundTint="#18FFFFFF"
        app:cornerRadius="26dp"
        app:rippleColor="#28FFFFFF"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Status text — sits above refresh -->
    <TextView
        android:id="@+id/statusText"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginBottom="18dp"
        android:text="@string/status_waiting"
        android:textColor="@color/text_muted"
        android:textSize="11sp"
        android:fontFamily="sans-serif"
        android:letterSpacing="0.04"
        android:gravity="center"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintBottom_toTopOf="@id/refreshButton" />

    <!-- Main weather block — vertically centered between top bar and status -->
    <LinearLayout
        android:id="@+id/weatherBlock"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center_horizontal"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toBottomOf="@id/settingsButton"
        app:layout_constraintBottom_toTopOf="@id/statusText"
        app:layout_constraintVertical_bias="0.42">

        <!-- Weather emoji — hero icon -->
        <TextView
            android:id="@+id/weatherIconText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="⛅"
            android:textSize="88sp"
            android:gravity="center"
            android:lineSpacingMultiplier="1.0" />

        <!-- Temperature — massive thin display -->
        <TextView
            android:id="@+id/temperatureText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="—°"
            android:textColor="@color/text_primary"
            android:textSize="96sp"
            android:fontFamily="sans-serif-thin"
            android:letterSpacing="-0.02"
            android:gravity="center"
            android:layout_marginTop="0dp" />

        <!-- Condition -->
        <TextView
            android:id="@+id/conditionText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="2dp"
            android:text="@string/weather_placeholder"
            android:textColor="@color/text_secondary"
            android:textSize="17sp"
            android:fontFamily="sans-serif-light"
            android:letterSpacing="0.05"
            android:gravity="center" />

        <!-- Wind speed -->
        <TextView
            android:id="@+id/windText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:text="— m/s"
            android:textColor="@color/text_muted"
            android:textSize="12sp"
            android:fontFamily="sans-serif"
            android:letterSpacing="0.04"
            android:gravity="center" />

    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
