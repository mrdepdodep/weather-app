<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/rootLayout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@drawable/bg_weather_cloudy"
        android:paddingStart="24dp"
        android:paddingEnd="24dp"
        android:paddingTop="60dp"
        android:paddingBottom="44dp">

        <!-- App label -->
        <TextView
            android:id="@+id/titleText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/title_weather"
            android:textColor="#94A3B8"
            android:textSize="11sp"
            android:textAllCaps="true"
            android:letterSpacing="0.3"
            android:fontFamily="sans-serif-medium"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toStartOf="@id/settingsButton" />

        <ImageButton
            android:id="@+id/settingsButton"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:background="@android:color/transparent"
            android:contentDescription="@string/settings_title"
            android:padding="8dp"
            android:src="@android:drawable/ic_menu_manage"
            android:tint="#94A3B8"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="@id/titleText"
            app:layout_constraintEnd_toEndOf="parent" />

        <!-- Location coordinates -->
        <TextView
            android:id="@+id/locationText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="@string/location_placeholder"
            android:textColor="#64748B"
            android:textSize="13sp"
            android:gravity="center"
            app:layout_constraintTop_toBottomOf="@id/titleText"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <!-- Weather emoji icon -->
        <TextView
            android:id="@+id/weatherIconText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="44dp"
            android:text="⛅"
            android:textSize="96sp"
            android:gravity="center"
            app:layout_constraintTop_toBottomOf="@id/locationText"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <!-- Temperature (large) -->
        <TextView
            android:id="@+id/temperatureText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="—°"
            android:textColor="#F8FAFC"
            android:textSize="88sp"
            android:fontFamily="sans-serif-thin"
            android:gravity="center"
            app:layout_constraintTop_toBottomOf="@id/weatherIconText"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <!-- Weather condition -->
        <TextView
            android:id="@+id/conditionText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:text="@string/weather_placeholder"
            android:textColor="#94A3B8"
            android:textSize="20sp"
            android:fontFamily="sans-serif-light"
            android:gravity="center"
            app:layout_constraintTop_toBottomOf="@id/temperatureText"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <!-- Info cards row -->
        <LinearLayout
            android:id="@+id/statsRow"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="44dp"
            android:orientation="horizontal"
            app:layout_constraintTop_toBottomOf="@id/conditionText"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <!-- Wind card -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginEnd="8dp"
                android:orientation="vertical"
                android:background="@drawable/bg_card"
                android:padding="20dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/wind_label"
                    android:textColor="#475569"
                    android:textSize="10sp"
                    android:textAllCaps="true"
                    android:letterSpacing="0.15"
                    android:fontFamily="sans-serif-medium" />

                <TextView
                    android:id="@+id/windText"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:text="— m/s"
                    android:textColor="#F8FAFC"
                    android:textSize="24sp"
                    android:fontFamily="sans-serif-medium" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:text="Wind Speed"
                    android:textColor="#475569"
                    android:textSize="11sp" />

            </LinearLayout>

            <!-- Status card -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="8dp"
                android:orientation="vertical"
                android:background="@drawable/bg_card"
                android:padding="20dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/status_label"
                    android:textColor="#475569"
                    android:textSize="10sp"
                    android:textAllCaps="true"
                    android:letterSpacing="0.15"
                    android:fontFamily="sans-serif-medium" />

                <TextView
                    android:id="@+id/statusText"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:text="@string/status_waiting"
                    android:textColor="#F8FAFC"
                    android:textSize="13sp"
                    android:fontFamily="sans-serif-medium"
                    android:minLines="2" />

            </LinearLayout>

        </LinearLayout>

        <!-- Refresh button -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/refreshButton"
            android:layout_width="0dp"
            android:layout_height="56dp"
            android:layout_marginTop="36dp"
            android:text="@string/refresh"
            android:textColor="#F8FAFC"
            android:textSize="15sp"
            android:textAllCaps="false"
            android:letterSpacing="0.04"
            android:fontFamily="sans-serif-medium"
            app:backgroundTint="@color/card_dark"
            app:strokeColor="@color/accent_blue"
            app:strokeWidth="1.5dp"
            app:cornerRadius="28dp"
            app:layout_constraintTop_toBottomOf="@id/statsRow"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

    </androidx.constraintlayout.widget.ConstraintLayout>
</ScrollView>
