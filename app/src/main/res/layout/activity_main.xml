<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/rootLayout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@drawable/bg_weather_cloudy"
        android:paddingStart="20dp"
        android:paddingEnd="20dp"
        android:paddingTop="56dp"
        android:paddingBottom="40dp">

        <!-- Subtle app label -->
        <TextView
            android:id="@+id/titleText"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="@string/title_weather"
            android:textColor="@color/text_muted"
            android:textSize="10sp"
            android:textAllCaps="true"
            android:letterSpacing="0.25"
            android:fontFamily="sans-serif-medium"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toStartOf="@id/settingsButton"
            app:layout_constraintBottom_toBottomOf="@id/settingsButton" />

        <!-- Settings button — glass circle -->
        <ImageButton
            android:id="@+id/settingsButton"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:background="@drawable/bg_settings_btn"
            android:contentDescription="@string/settings_title"
            android:padding="10dp"
            android:src="@android:drawable/ic_menu_manage"
            android:tint="@color/accent_blue"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <!-- Location pill chip — centered -->
        <TextView
            android:id="@+id/locationText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="28dp"
            android:text="@string/location_placeholder"
            android:textColor="@color/text_secondary"
            android:textSize="13sp"
            android:fontFamily="sans-serif-medium"
            android:paddingStart="18dp"
            android:paddingEnd="18dp"
            android:paddingTop="8dp"
            android:paddingBottom="8dp"
            android:background="@drawable/bg_location_chip"
            app:layout_constraintTop_toBottomOf="@id/settingsButton"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <!-- Weather emoji — hero icon -->
        <TextView
            android:id="@+id/weatherIconText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="32dp"
            android:text="⛅"
            android:textSize="100sp"
            android:gravity="center"
            app:layout_constraintTop_toBottomOf="@id/locationText"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <!-- Temperature — massive thin display -->
        <TextView
            android:id="@+id/temperatureText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="0dp"
            android:text="—°"
            android:textColor="@color/text_primary"
            android:textSize="96sp"
            android:fontFamily="sans-serif-thin"
            android:letterSpacing="-0.02"
            android:gravity="center"
            app:layout_constraintTop_toBottomOf="@id/weatherIconText"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <!-- Weather condition -->
        <TextView
            android:id="@+id/conditionText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="@string/weather_placeholder"
            android:textColor="@color/text_secondary"
            android:textSize="18sp"
            android:fontFamily="sans-serif-light"
            android:letterSpacing="0.05"
            android:gravity="center"
            app:layout_constraintTop_toBottomOf="@id/temperatureText"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <!-- Info cards row -->
        <LinearLayout
            android:id="@+id/statsRow"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="40dp"
            android:orientation="horizontal"
            app:layout_constraintTop_toBottomOf="@id/conditionText"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <!-- Wind card -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginEnd="8dp"
                android:orientation="vertical"
                android:background="@drawable/bg_card"
                android:padding="20dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/wind_label"
                    android:textColor="@color/text_muted"
                    android:textSize="10sp"
                    android:textAllCaps="true"
                    android:letterSpacing="0.2"
                    android:fontFamily="sans-serif-medium" />

                <TextView
                    android:id="@+id/windText"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:text="— m/s"
                    android:textColor="@color/text_primary"
                    android:textSize="24sp"
                    android:fontFamily="sans-serif-medium" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:text="Wind Speed"
                    android:textColor="@color/text_muted"
                    android:textSize="11sp" />

            </LinearLayout>

            <!-- Status card -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="8dp"
                android:orientation="vertical"
                android:background="@drawable/bg_card"
                android:padding="20dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/status_label"
                    android:textColor="@color/text_muted"
                    android:textSize="10sp"
                    android:textAllCaps="true"
                    android:letterSpacing="0.2"
                    android:fontFamily="sans-serif-medium" />

                <TextView
                    android:id="@+id/statusText"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:text="@string/status_waiting"
                    android:textColor="@color/text_primary"
                    android:textSize="13sp"
                    android:fontFamily="sans-serif-medium"
                    android:minLines="2" />

            </LinearLayout>

        </LinearLayout>

        <!-- Refresh button — glowing outlined pill -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/refreshButton"
            android:layout_width="0dp"
            android:layout_height="56dp"
            android:layout_marginTop="28dp"
            android:text="@string/refresh"
            android:textColor="@color/accent_blue"
            android:textSize="15sp"
            android:textAllCaps="false"
            android:letterSpacing="0.06"
            android:fontFamily="sans-serif-medium"
            app:backgroundTint="@color/card_dark"
            app:strokeColor="@color/accent_blue"
            app:strokeWidth="1.5dp"
            app:cornerRadius="28dp"
            app:layout_constraintTop_toBottomOf="@id/statsRow"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

    </androidx.constraintlayout.widget.ConstraintLayout>
</ScrollView>
